APP_ENV=local
LOG_LEVEL=info

# Backend dev defaults. Keep real values in .env only.
DATABASE_URL=sqlite:///runtime/db/ezviz-panel.db
EZVIZ_BACKEND_SECRET_KEY=change-this-local-dev-secret
EZVIZ_SECRETS_ENV_FILE=C:\Users\Pawel Z\OneDrive\Documents\kamery podgląd\config\secrets.local.env
ACCESS_TOKEN_EXPIRE_MINUTES=720
ADMIN_USERNAME=admin
ADMIN_PASSWORD_CHANGE_ME=change-me

# Optional paths for camera-probe when binaries are not in PATH.
FFPROBE_BIN=ffprobe
FFMPEG_BIN=ffmpeg
